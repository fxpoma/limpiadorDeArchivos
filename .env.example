# Configuración de la aplicación Flask
# Copia este archivo a .env y completa los valores

# Clave secreta para Flask (IMPORTANTE: cambia esto en producción)
SECRET_KEY=tu-clave-secreta-aqui-cambiala

# Puerto donde correra la aplicacion
FLASK_RUN_PORT=5000

# Modo de debug (false en produccion)
FLASK_DEBUG=false
